{
  "name": "agent-junction-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time desktop monitor for Agent Junction inter-agent communication",
  "author": {
    "name": "Daniel Rosehill",
    "email": "public@danielrosehill.com"
  },
  "homepage": "https://github.com/danielrosehill/Agent-Junction",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.agentjunction.monitor",
    "productName": "Agent Junction Monitor",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": ["deb"],
      "category": "Development;Utility",
      "icon": "build/icons",
      "desktop": {
        "Name": "Agent Junction Monitor",
        "Comment": "Real-time monitor for Agent Junction inter-agent communication",
        "Terminal": "false",
        "Type": "Application",
        "Categories": "Development;Utility"
      }
    },
    "deb": {
      "depends": ["libnotify4", "libappindicator3-1", "libsecret-1-0"]
    }
  }
}
